<?xml version="1.0" encoding="utf-8"?>
<UI version="1">
  <!-- 模板：用 <Btn> 原语 + 子节点 <Text> 组合出彩色按钮，无需 prefab -->
  <Template name="PrimaryButton">
    <Param name="text"/>
    <Btn color="#3B82F6">
      <Text anchor="stretch" align="center" color="#FFFFFF" size="24"
            raycastTarget="false">{{text}}</Text>
    </Btn>
  </Template>

  <Template name="DangerButton">
    <Param name="text"/>
    <Btn color="#DC2626">
      <Text anchor="stretch" align="center" color="#FFFFFF" size="24"
            raycastTarget="false">{{text}}</Text>
    </Btn>
  </Template>

  <Screen name="MainMenu">
    <Image id="bg" anchor="stretch" color="#222244"/>
    <VStack id="menuRoot" anchor="center" size="280x240" spacing="16" padding="16">
      <PrimaryButton id="playBtn"     size="240x64" text="开始游戏"/>
      <PrimaryButton id="settingsBtn" size="240x64" text="设置"/>
      <DangerButton  id="quitBtn"     size="240x64" text="退出"/>
    </VStack>
  </Screen>
</UI>
